# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# These files must always use LF
Dockerfile text eol=lf
*.sh text eol=lf
*.py text eol=lf
requirements.txt text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.mjs text eol=lf
*.bat text eol=crlf